OPENAI_API_KEY=你的OpenAI_API_Key
OPENAI_BASE_URL=https://your-proxy-domain/v1

OKX_API_KEY=你的OKX_API_Key
OKX_API_SECRET=你的OKX_API_Secret
OKX_API_PASSPHRASE=你的OKX_API_Passphrase

OPENAI_MODEL=gpt-5.5
BACKTEST_FILE=user_data/backtest_results/backtest-result.json
AI_ANALYSIS_FILE=user_data/backtest_results/ai-analysis.txt
AI_STRATEGY_FILE=user_data/strategies/AI_Generated_Strategy.py
# ========== AI 总开关 ==========
AI_MODEL_SWITCH_ON_ERROR=true
AI_MODEL_MAX_ATTEMPTS_PER_CALL=5
AI_MODEL_TIMEOUT_SECONDS=180
AI_CALL_COOLDOWN_SECONDS=10
ADVISOR_TO_CODEGEN_DELAY_SECONDS=5

# ========== 策略顾问 / 代码生成 Provider 池 ==========
# 配置后会优先使用 provider 池；未配置时仍兼容 OPENAI_* / CLAUDE_* / *_MODEL_POOL 旧变量。
STRATEGY_ADVISOR_PROVIDER_POOL=apihost_claude_opus47,apihost_claude_opus46,deepseek_official,glm_official
STRATEGY_CODEGEN_PROVIDER_POOL=apihost_claude_opus47,apihost_claude_opus46,deepseek_official,glm_official

# ========== Provider: apihost claude opus 4.7 ==========
AI_PROVIDER_APIHOST_CLAUDE_OPUS47_BASE_URL=https://apihost.cn/v1
AI_PROVIDER_APIHOST_CLAUDE_OPUS47_API_KEY=你的key
AI_PROVIDER_APIHOST_CLAUDE_OPUS47_MODEL=claude-opus-4-7
AI_PROVIDER_APIHOST_CLAUDE_OPUS47_TYPE=openai_compatible

# ========== Provider: apihost claude opus 4.6 ==========
AI_PROVIDER_APIHOST_CLAUDE_OPUS46_BASE_URL=https://apihost.cn/v1
AI_PROVIDER_APIHOST_CLAUDE_OPUS46_API_KEY=你的key
AI_PROVIDER_APIHOST_CLAUDE_OPUS46_MODEL=claude-opus-4-6
AI_PROVIDER_APIHOST_CLAUDE_OPUS46_TYPE=openai_compatible

# ========== Provider: DeepSeek 官方 ==========
AI_PROVIDER_DEEPSEEK_OFFICIAL_BASE_URL=你的deepseek_base_url
AI_PROVIDER_DEEPSEEK_OFFICIAL_API_KEY=你的deepseek_key
AI_PROVIDER_DEEPSEEK_OFFICIAL_MODEL=你的deepseek模型名
AI_PROVIDER_DEEPSEEK_OFFICIAL_TYPE=openai_compatible

# ========== Provider: GLM / 智谱官方 ==========
AI_PROVIDER_GLM_OFFICIAL_BASE_URL=你的glm_base_url
AI_PROVIDER_GLM_OFFICIAL_API_KEY=你的glm_key
AI_PROVIDER_GLM_OFFICIAL_MODEL=你的glm模型名
AI_PROVIDER_GLM_OFFICIAL_TYPE=openai_compatible
