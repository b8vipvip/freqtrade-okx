{
  "strategy_advisor": {
    "enabled": true,
    "provider": "openai_compatible",
    "base_url_env": "CLAUDE_BASE_URL",
    "api_key_env": "CLAUDE_API_KEY",
    "model_env": "CLAUDE_MODEL",
    "default_model": "claude-opus-4-7",
    "model_pool_env": "CLAUDE_MODEL_POOL"
  },
  "code_generator": {
    "enabled": true,
    "provider": "openai_compatible",
