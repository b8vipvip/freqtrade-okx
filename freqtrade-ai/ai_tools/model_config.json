    "default_model": "gpt-5.5",
    "model_pool_env": "OPENAI_MODEL_POOL"
  },
  "code_repair": {
    "enabled": true,
    "provider": "openai_compatible",
    "base_url_env": "OPENAI_BASE_URL",
    "api_key_env": "OPENAI_API_KEY",
    "model_env": "OPENAI_MODEL",
    "default_model": "gpt-5.5",
    "model_pool_env": "OPENAI_MODEL_POOL"
  }
}
